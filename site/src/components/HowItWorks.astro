---
import type { Translations } from '../i18n/index';

interface Props { t: Translations; }
const { t } = Astro.props;

const steps = [
  { num: '1', title: t.how.step1Title, body: t.how.step1Body },
  { num: '2', title: t.how.step2Title, body: t.how.step2Body },
  { num: '3', title: t.how.step3Title, body: t.how.step3Body },
];
---
<section class="section section-alt" id="how" aria-labelledby="how-h2">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">{t.how.eyebrow}</p>
      <h2 id="how-h2">{t.how.h2}</h2>
    </div>

    <div class="steps" role="list">
      {steps.map((s, i) => (
        <div class={`step reveal`} style={`transition-delay: ${i * 100}ms`} role="listitem">
          <div class="step-num" aria-hidden="true">{s.num}</div>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
          <div class="step-screen" aria-hidden="true">
            <div class="placeholder">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" opacity="0.4">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 13h4"/>
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-alt { background: var(--bg); }
  .section-head { text-align: center; margin-bottom: 48px; max-width: 680px; margin-left: auto; margin-right: auto; }
  .section-head h2 { margin: 0 0 16px; }

  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .step { position: relative; }
  .step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fff;
    border: 1px solid var(--divider);
    display: grid;
    place-items: center;
    font-weight: 700;
    color: var(--primary);
    font-size: 14px;
    margin-bottom: 18px;
  }
  .step h3 { margin-bottom: 8px; }
  .step p { color: var(--text-2); font-size: 15px; }
  .step-screen {
    margin-top: 18px;
    border: 1px solid var(--divider);
    border-radius: var(--radius);
    overflow: hidden;
    background: #0E1116;
    height: 160px;
    position: relative;
  }
  .step-screen .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--app-muted);
    font-size: 12px;
    letter-spacing: .06em;
    text-transform: uppercase;
    background: repeating-linear-gradient(45deg, #0E1116, #0E1116 8px, #171B22 8px, #171B22 16px);
  }

  @media (max-width: 768px) { .steps { grid-template-columns: 1fr; } }
</style>
