---
import type { Translations } from '../i18n/index';

interface Props { t: Translations; }
const { t } = Astro.props;

const cards = [
  {
    title: t.features.card1Title,
    body:  t.features.card1Body,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 14l3 3 3-3"/><path d="M12 11v6"/></svg>`,
    accentClass: '',
  },
  {
    title: t.features.card2Title,
    body:  t.features.card2Body,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 8.5l1 2.2 2.2 1-2.2 1-1 2.2-1-2.2-2.2-1 2.2-1z"/></svg>`,
    accentClass: 'accent',
  },
  {
    title: t.features.card3Title,
    body:  t.features.card3Body,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>`,
    accentClass: '',
  },
  {
    title: t.features.card4Title,
    body:  t.features.card4Body,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1.2" fill="currentColor"/></svg>`,
    accentClass: 'accent',
  },
];
---
<section class="section" id="features" aria-labelledby="features-h2">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">{t.features.eyebrow}</p>
      <h2 id="features-h2">{t.features.h2}</h2>
      <p class="lede">{t.features.lede}</p>
    </div>
    <div class="features" role="list">
      {cards.map((c, i) => (
        <div class={`feat-card reveal`} style={`transition-delay: ${i * 80}ms`} role="listitem">
          <div class={`feat-icon ${c.accentClass}`} aria-hidden="true" set:html={c.icon} />
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-head { text-align: center; margin-bottom: 48px; max-width: 680px; margin-left: auto; margin-right: auto; }
  .section-head h2 { margin: 0 0 16px; }
  .lede { color: var(--text-2); font-size: 18px; line-height: 1.65; max-width: 56ch; margin: 0 auto; }

  .features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .feat-card {
    background: #fff;
    border: 1px solid var(--divider);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    transition: border-color .18s, transform .18s, box-shadow .18s;
  }
  .feat-card:hover {
    border-color: #C9D1DA;
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }
  .feat-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(30, 136, 229, .08);
    color: var(--primary);
    display: grid;
    place-items: center;
    margin-bottom: 18px;
  }
  .feat-icon.accent { background: rgba(0, 191, 165, .10); color: var(--accent); }
  .feat-card h3 { margin-bottom: 8px; font-size: 17px; letter-spacing: -0.012em; }
  .feat-card p { color: var(--text-2); font-size: 15px; line-height: 1.55; }

  @media (max-width: 980px) { .features { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .features { grid-template-columns: 1fr; } }
</style>
