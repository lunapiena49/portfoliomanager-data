---
// Shared FAQ page body (W7.D-CC.2). Renders the 8 Q/A pairs from i18n
// (`t.faq.q1..q8` / `t.faq.a1..a8`) inside the LegalLayout and emits a
// schema.org FAQPage JSON-LD block for Google Rich Results.
//
// Used by `/faq/` (it) and `/<lang>/faq/` for en/es/fr/de/pt. Translations
// already exist in src/i18n/*.ts; this component is a presentation-only
// wrapper, no string duplication.

import LegalLayout from '../layouts/LegalLayout.astro';
import type { Translations, Locale } from '../i18n/index';

interface Props {
  t: Translations;
  lang: Locale;
}

const { t, lang } = Astro.props;

const items = [
  { q: t.faq.q1, a: t.faq.a1 },
  { q: t.faq.q2, a: t.faq.a2 },
  { q: t.faq.q3, a: t.faq.a3 },
  { q: t.faq.q4, a: t.faq.a4 },
  { q: t.faq.q5, a: t.faq.a5 },
  { q: t.faq.q6, a: t.faq.a6 },
  { q: t.faq.q7, a: t.faq.a7 },
  { q: t.faq.q8, a: t.faq.a8 },
];

const toc = items.map((item, i) => ({
  id: `q${i + 1}`,
  label: item.q.length > 55 ? item.q.slice(0, 52) + '...' : item.q,
}));

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---
<LegalLayout t={t} lang={lang} pageTitle={t.faq.h2} tocItems={toc}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  {items.map((item, i) => (
    <section id={`q${i + 1}`} class="faq-section">
      <h2>{item.q}</h2>
      <p>{item.a}</p>
    </section>
  ))}
</LegalLayout>

<style>
  .faq-section h2 {
    scroll-margin-top: 88px;
  }
</style>
