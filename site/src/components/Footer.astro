---
import type { Translations, Locale } from '../i18n/index';
import { LOCALES } from '../i18n/index';

interface Props {
  t: Translations;
  currentLang: Locale;
}

const { t, currentLang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function langUrl(l: Locale) {
  return l === 'it' ? `${base}/` : `${base}/${l}/`;
}

function legalUrl(page: string) {
  return currentLang === 'it' ? `${base}/${page}` : `${base}/${currentLang}/${page}`;
}
---
<footer role="contentinfo">
  <div class="wrap">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href={`${base}/`} class="footer-logo" aria-label="PluriFin home">
          <span class="brand-mark" aria-hidden="true">P</span>
          <span class="brand-name">PluriFin</span>
        </a>
        <p>{t.footer.tagline}</p>
        <p class="copy">{t.footer.copyright}</p>
      </div>

      <!-- Product -->
      <nav aria-label={t.footer.colProduct}>
        <h3>{t.footer.colProduct}</h3>
        <ul>
          <li><a href={`${base}/app/`}>{t.footer.linkWebapp}</a></li>
          <li><a href="#" aria-disabled="true">{t.footer.linkPlayStore}</a></li>
          <li><a href="https://github.com/lunapiena49/portfoliomanager-data/releases" rel="noopener noreferrer" target="_blank">{t.footer.linkChangelog}</a></li>
          <li><a href={legalUrl('about')}>{t.footer.linkAbout}</a></li>
        </ul>
      </nav>

      <!-- Legal -->
      <nav aria-label={t.footer.colLegal}>
        <h3>{t.footer.colLegal}</h3>
        <ul>
          <li><a href={legalUrl('privacy')}>{t.footer.linkPrivacy}</a></li>
          <li><a href={legalUrl('terms')}>{t.footer.linkTerms}</a></li>
          <li><a href={legalUrl('disclaimer')}>{t.footer.linkDisclaimer}</a></li>
          <li><a href="mailto:plurifin.app+gdpr@gmail.com">{t.footer.linkGdpr}</a></li>
        </ul>
      </nav>

      <!-- Contact -->
      <nav aria-label={t.footer.colContact}>
        <h3>{t.footer.colContact}</h3>
        <ul>
          <li>
            <a href="mailto:plurifin.app@gmail.com">
              {t.footer.linkEmail}
              <span class="email-address">plurifin.app@gmail.com</span>
            </a>
          </li>
          <li>
            <a href="https://github.com/lunapiena49/portfoliomanager-data" rel="noopener noreferrer" target="_blank">
              {t.footer.linkGithub}
            </a>
          </li>
          <li>
            <a href={legalUrl('contact')}>
              {t.footer.linkGdpr}
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <nav class="footer-langs" aria-label={t.nav.langLabel}>
        {LOCALES.map(l => (
          <a
            href={langUrl(l)}
            class={l === currentLang ? 'active' : ''}
            aria-current={l === currentLang ? 'page' : undefined}
            lang={l}
          >
            {l.toUpperCase()}
          </a>
        ))}
      </nav>
      <span class="footer-bid" aria-label="Bundle ID">{t.footer.bundleId}</span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #0E1116;
    color: #B7BDC6;
    padding: 64px 0 32px;
    font-size: 14px;
  }
  footer nav h3 {
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    margin: 0 0 18px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
  }
  .brand-name { font-weight: 600; font-size: 15px; letter-spacing: -0.01em; color: #fff; }
  .footer-brand p { color: #B7BDC6; max-width: 30ch; font-size: 13px; line-height: 1.55; margin-bottom: 8px; }
  .footer-brand .copy { color: #9099A6; font-size: 12px; margin-top: 12px; }
  footer ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  footer ul a { color: #B7BDC6; font-size: 14px; transition: color .15s; text-decoration: none; display: flex; flex-direction: column; gap: 2px; }
  footer ul a:hover { color: #fff; }
  .email-address { font-size: 12px; color: #9099A6; }
  footer ul a[aria-disabled="true"] { opacity: .5; cursor: not-allowed; pointer-events: none; }
  .footer-bottom {
    border-top: 1px solid #1F2530;
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    color: #5A6670;
    font-size: 12px;
  }
  .footer-langs {
    display: flex;
    gap: 4px;
    background: #1F2530;
    border-radius: 999px;
    padding: 4px;
  }
  .footer-langs a {
    display: block;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    color: #B7BDC6;
    letter-spacing: .06em;
    text-decoration: none;
    transition: background .15s, color .15s;
  }
  .footer-langs a.active { background: #fff; color: var(--text); }
  .footer-langs a:hover:not(.active) { background: rgba(255,255,255,.08); color: #fff; }
  .footer-bid { font-family: ui-monospace, monospace; font-size: 11px; color: #3F4754; }

  @media (max-width: 880px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
  @media (max-width: 560px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
