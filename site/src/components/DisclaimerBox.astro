---
import type { Translations } from '../i18n/index';

interface Props { t: Translations; lang: string; }
const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const disclaimerUrl = lang === 'it' ? `${base}/disclaimer` : `${base}/${lang}/disclaimer`;
---
<section class="section section-alt" id="disclaimer" aria-labelledby="disclaimer-h3">
  <div class="wrap">
    <div class="disclaimer-box reveal" role="note" aria-label={t.disclaimer.h3}>
      <div class="ico" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
          <path d="M10.3 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.7 3.86a2 2 0 0 0-3.4 0z"/>
          <path d="M12 9v4"/><path d="M12 17h.01"/>
        </svg>
      </div>
      <div>
        <h3 id="disclaimer-h3">{t.disclaimer.h3}</h3>
        <p>{t.disclaimer.body}</p>
        <a href={disclaimerUrl} class="read-more">
          {t.disclaimer.cta}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-alt { background: var(--bg); }
  .disclaimer-box {
    background: var(--warn-bg);
    border: 1px solid var(--warn-border);
    border-radius: var(--radius-lg);
    padding: 28px 32px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .disclaimer-box .ico {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 10px;
    background: rgba(255, 152, 0, .15);
    color: #B26A00;
    display: grid;
    place-items: center;
  }
  .disclaimer-box h3 { font-size: 17px; margin-bottom: 8px; color: var(--text); }
  .disclaimer-box p { font-size: 15px; color: var(--text-2); line-height: 1.6; margin-bottom: 12px; }
  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
    font-size: 14px;
    color: var(--primary);
  }
  .read-more:hover { color: var(--primary-dark); }

  @media (max-width: 560px) {
    .disclaimer-box { flex-direction: column; padding: 20px; }
  }
</style>
