---
import type { Translations } from '../i18n/index';

interface Props { t: Translations; }
const { t } = Astro.props;

const brokers = [
  'Interactive Brokers',
  'TD Ameritrade',
  'Fidelity',
  'Charles Schwab',
  'E*TRADE',
  'Robinhood',
  'Vanguard',
  'DEGIRO',
  'Trading 212',
  'XTB',
  'Revolut',
];
---
<section class="section section-alt" id="brokers" aria-labelledby="brokers-h2">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">{t.brokers.eyebrow}</p>
      <h2 id="brokers-h2">{t.brokers.h2}</h2>
      <p class="lede">{t.brokers.lede}</p>
    </div>

    <div class="brokers reveal" role="list" aria-label="Supported brokers">
      {brokers.map(b => (
        <div class="brk" role="listitem">{b}</div>
      ))}
      <div class="brk generic" role="listitem">
        <span>Generic CSV</span>
      </div>
    </div>

    <p class="brokers-foot reveal">
      {t.brokers.foot}
    </p>
  </div>
</section>

<style>
  .section-alt { background: var(--bg); }

  .section-head { text-align: center; margin-bottom: 48px; max-width: 680px; margin-left: auto; margin-right: auto; }
  .section-head h2 { margin: 0 0 16px; }
  .lede { color: var(--text-2); font-size: 18px; line-height: 1.65; max-width: 56ch; margin: 0 auto; }

  .brokers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .brk {
    background: #fff;
    border: 1px solid var(--divider);
    border-radius: 8px;
    height: 74px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
    text-align: center;
    padding: 0 12px;
    transition: border-color .18s, background .18s;
  }
  .brk:hover { border-color: #B7BDC6; background: #fafbfc; }
  .brk.generic { border-style: dashed; color: var(--text-2); }
  .brokers-foot {
    margin-top: 24px;
    font-size: 14px;
    color: var(--text-2);
    text-align: center;
  }

  @media (max-width: 980px) { .brokers { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) {
    .brokers { grid-template-columns: repeat(2, 1fr); }
    .brk { height: 64px; font-size: 12px; }
  }
</style>
