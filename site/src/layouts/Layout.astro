---
import '../styles/global.css';
import type { Locale } from '../i18n/index';
import { LOCALES } from '../i18n/index';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  lang: Locale;
  canonicalPath?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  lang,
  canonicalPath = '',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://lunapiena49.github.io/portfoliomanager-data';
const canonicalUrl = `${siteUrl}${canonicalPath ? '/' + canonicalPath : ''}`;
const ogImageUrl = `${siteUrl}/assets/og-image.png`;

// GoatCounter analytics. Self-hosted on Cloudflare Workers (zero-cost,
// no-cookie, GDPR-safe, no IP storage). Setup notes:
//   marketing/analytics/goatcounter_setup.md
// Set GOATCOUNTER_HOST at build time, e.g.:
//   GOATCOUNTER_HOST=stats.plurifin.app astro build
// If unset, no tracking script is emitted (silent no-op).
const goatcounterHost = import.meta.env.GOATCOUNTER_HOST as string | undefined;
---
<!DOCTYPE html>
<html lang={lang} dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={lang} />
  <meta property="og:site_name" content="PluriFin" />

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Alternate locales -->
  {LOCALES.map(l => {
    const prefix = l === 'it' ? '' : `/${l}`;
    return <link rel="alternate" hreflang={l} href={`${siteUrl}${prefix}`} />;
  })}
  <link rel="alternate" hreflang="x-default" href={siteUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}/assets/favicon.svg`} />
  <link rel="apple-touch-icon" href={`${base}/assets/apple-touch-icon.png`} />

  <!-- Inter variable font (rsms.me CDN -- cached globally, 0 layout shift) -->
  <link rel="preconnect" href="https://rsms.me/" />
  <link rel="preload" as="style" href="https://rsms.me/inter/inter.css" />
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

  <!-- Robots -->
  <meta name="robots" content="index, follow" />

  <!-- Theme color -->
  <meta name="theme-color" content="#1E88E5" />

  <!-- JSON-LD SoftwareApplication (Schema.org) for richer SERP cards -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Portfolio Manager",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Android, Web",
    "url": canonicalUrl,
    "image": ogImageUrl,
    "description": ogDescription ?? description,
    "inLanguage": lang,
    "softwareVersion": "1.0.0",
    "datePublished": "2026-05-02",
    "publisher": {
      "@type": "Person",
      "name": "Filippo Salemi",
      "alternateName": "PluriFin",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "IT"
      }
    },
    "offers": [
      {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "name": "Web demo (free)"
      },
      {
        "@type": "Offer",
        "price": "0.99",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "name": "Premium Android (1 year, with 7-day trial)"
      }
    ]
  })} />
</head>
<body>
  <a href="#main" class="skip">Skip to content</a>
  <slot />

  {/* GoatCounter analytics (no-cookie, GDPR-safe). Emitted only when
      GOATCOUNTER_HOST is set at build time. */}
  {goatcounterHost && (
    <script
      data-goatcounter={`https://${goatcounterHost}/count`}
      async
      src="//gc.zgo.at/count.js"
    />
  )}

  <!-- Intersection Observer for reveal animations -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
