---
import Layout from './Layout.astro';
import type { Translations, Locale } from '../i18n/index';

interface Props {
  t: Translations;
  lang: Locale;
  pageTitle: string;
  tocItems: Array<{ id: string; label: string }>;
}

const { t, lang, pageTitle, tocItems } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeUrl = lang === 'it' ? `${base}/` : `${base}/${lang}/`;
---
<Layout
  title={`${pageTitle} -- PluriFin`}
  description={pageTitle}
  lang={lang}
>
  <!-- Mini navbar -->
  <nav class="nav" role="navigation" aria-label="Site navigation">
    <div class="wrap nav-inner">
      <a href={homeUrl} class="brand" aria-label="PluriFin home">
        <span class="brand-mark" aria-hidden="true">P</span>
        <span class="brand-name">PluriFin</span>
      </a>
      <span class="nav-spacer" aria-hidden="true"></span>
      <a href={homeUrl} class="nav-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        {t.legal.backHome}
      </a>
    </div>
  </nav>

  <main id="main">
    <div class="wrap">
      <!-- Breadcrumb -->
      <nav class="bread" aria-label="Breadcrumb">
        <a href={homeUrl}>Home</a>
        <span class="sep" aria-hidden="true">/</span>
        <span>{pageTitle}</span>
      </nav>

      <div class="page-layout">
        <!-- TOC sidebar -->
        <aside class="toc" aria-label="Table of contents">
          <h4>In questa pagina</h4>
          <ul role="list">
            {tocItems.map((item, i) => (
              <li>
                <a href={`#${item.id}`} class={i === 0 ? 'active' : ''}>{item.label}</a>
              </li>
            ))}
          </ul>
        </aside>

        <!-- Content -->
        <article class="prose">
          <h1>{pageTitle}</h1>
          <slot />
        </article>
      </div>
    </div>
  </main>

  <footer class="mini-footer" role="contentinfo">
    <div class="wrap">
      {t.footer.copyright} &middot;
      <a href={homeUrl}>{t.legal.backHome}</a>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(248,249,250,.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--divider);
  }
  .nav-inner { display: flex; align-items: center; gap: 24px; height: 68px; }
  .brand { display: flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; }
  .brand-mark {
    width: 30px; height: 30px; border-radius: 8px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: grid; place-items: center; color: #fff; font-weight: 700; font-size: 14px;
  }
  .brand-name { font-weight: 600; font-size: 16px; letter-spacing: -0.01em; }
  .nav-spacer { flex: 1; }
  .nav-back { font-size: 14px; color: var(--text-2); text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: color .15s; }
  .nav-back:hover { color: var(--text); }

  .bread { font-size: 13px; color: var(--text-3); margin: 28px 0 8px; display: flex; gap: 8px; align-items: center; }
  .bread a { color: var(--text-2); text-decoration: none; }
  .bread a:hover { color: var(--text); }
  .bread .sep { color: var(--text-3); }

  .page-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 64px;
    padding: 32px 0 96px;
    align-items: flex-start;
  }

  .toc { position: sticky; top: 84px; font-size: 14px; }
  .toc h4 { font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--text-3); margin: 0 0 12px; }
  .toc ul { list-style: none; margin: 0; padding: 0; border-left: 1px solid var(--divider); display: flex; flex-direction: column; gap: 2px; }
  .toc a {
    display: block; padding: 6px 14px; color: var(--text-2); text-decoration: none;
    border-left: 2px solid transparent; margin-left: -1px; font-size: 13px; line-height: 1.4;
    transition: color .12s, border-color .12s;
  }
  .toc a:hover { color: var(--text); }
  .toc a.active { color: var(--primary); border-left-color: var(--primary); font-weight: 500; }

  .prose { max-width: 720px; }
  .prose h1 { margin-bottom: 8px; }
  :global(.prose .meta) { color: var(--text-3); font-size: 13px; margin-bottom: 32px; }
  :global(.prose h2) { font-size: 24px; line-height: 1.3; margin: 48px 0 12px; }
  :global(.prose h3) { font-size: 18px; margin: 24px 0 8px; }
  :global(.prose p) { color: var(--text-2); font-size: 16px; line-height: 1.65; margin-bottom: 14px; }
  :global(.prose ul) { padding-left: 24px; margin: 8px 0 16px; }
  :global(.prose li) { margin-bottom: 6px; color: var(--text-2); font-size: 15px; line-height: 1.6; }
  :global(.prose strong) { color: var(--text); font-weight: 600; }
  :global(.prose a) { color: var(--primary); }
  :global(.prose a:hover) { color: var(--primary-dark); }
  :global(.prose hr) { border: 0; border-top: 1px solid var(--divider); margin: 32px 0; }
  :global(.prose .callout) {
    background: rgba(0,191,165,.06);
    border: 1px solid rgba(0,191,165,.18);
    border-radius: 10px;
    padding: 18px 20px;
    margin: 20px 0;
    font-size: 15px;
  }
  :global(.prose .note) {
    background: var(--warn-bg);
    border: 1px solid var(--warn-border);
    border-radius: 10px;
    padding: 16px 20px;
    font-size: 14px;
    color: var(--text-2);
    margin: 20px 0;
  }

  .mini-footer {
    background: #0E1116;
    color: #8A93A0;
    padding: 32px 0;
    font-size: 13px;
    text-align: center;
  }
  .mini-footer a { color: #B7BDC6; text-decoration: none; }
  .mini-footer a:hover { color: #fff; }

  @media (max-width: 880px) {
    .page-layout { grid-template-columns: 1fr; gap: 32px; padding: 24px 0 64px; }
    .toc { position: static; }
  }
</style>

<script>
  // Highlight active TOC item on scroll
  const tocLinks = document.querySelectorAll('.toc a');
  const sections = Array.from(document.querySelectorAll('[id]'));
  const obs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        tocLinks.forEach(a => a.classList.remove('active'));
        const link = document.querySelector(`.toc a[href="#${entry.target.id}"]`);
        link?.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });
  sections.forEach(s => obs.observe(s));
</script>
